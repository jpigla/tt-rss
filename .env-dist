# Copy this file to .env before building the container. Put any local modifications here.

# Run FPM under this UID/GID.
# OWNER_UID=1000
# OWNER_GID=1000

# FPM settings.
#PHP_WORKER_MAX_CHILDREN=5
#PHP_WORKER_MEMORY_LIMIT=256M

# ADMIN_USER_* settings are applied on every startup.

# Set admin user password to this value. If not set, random password will be generated on startup, look for it in the 'app' container logs.
#ADMIN_USER_PASS=

# Sets admin user access level to this value. Valid values:
# -2 - forbidden to login
# -1 - readonly
#  0 - default user
# 10 - admin
#ADMIN_USER_ACCESS_LEVEL=

# Auto create another user (in addition to built-in admin) unless it already exists.
#AUTO_CREATE_USER=
#AUTO_CREATE_USER_PASS=
#AUTO_CREATE_USER_ACCESS_LEVEL=0

# Default database credentials.
# ACHTUNG: Im Produktionsbetrieb sichere Passwörter verwenden!
TTRSS_DB_USER=postgres
TTRSS_DB_NAME=postgres
TTRSS_DB_PASS=password

# Vollständige URL zur tt-rss-Instanz — MUSS für Produktionsbetrieb gesetzt werden.
# Wird für korrekte Redirect-URLs, Feed-Links und API-Antworten benötigt.
# TTRSS_SELF_URL_PATH=https://rss.example.com/tt-rss

# Session-Lebensdauer in Sekunden (Standard: 86400 = 1 Tag).
# Für mobilen Betrieb empfehlen sich längere Sessions:
# TTRSS_SESSION_COOKIE_LIFETIME=2592000

# Weitere config.php-Overrides (vollständige Liste: tt-rss/.docker/app/Dockerfile):
# TTRSS_PLUGINS=auth_internal, note, nginx_xaccel
# TTRSS_SINGLE_USER_MODE=true
# TTRSS_FORCE_ARTICLE_PURGE=30

# Port-Binding: 127.0.0.1 für Betrieb hinter einem Reverse-Proxy (empfohlen).
# Ohne "127.0.0.1:" ist der Port direkt im Netz erreichbar.
HTTP_PORT=127.0.0.1:8280
#HTTP_PORT=8280

# Edge-TTS API-Key (für das TTS-Plugin). Einen sicheren Key generieren:
# openssl rand -hex 32
EDGE_TTS_API_KEY=

